/* pages/order/order.wxss */
.tab-bar {
  display: flex;
  background: var(--color-white);
  border-radius: var(--border-radius-md);
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  color: var(--color-primary);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 30%;
  width: 40%;
  height: 6rpx;
  background: linear-gradient(90deg, var(--color-primary), var(--color-primary-dark));
  border-radius: 3rpx;
}

.order-card {
  background: var(--color-white);
  border-radius: var(--border-radius-md);
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s;
}
.order-card:active {
  transform: scale(0.98);
}

.order-book {
  display: flex;
  align-items: center;
}

.order-book-img {
  width: 120rpx;
  height: 160rpx;
  border-radius: var(--border-radius-sm);
  margin-right: 20rpx;
  background: var(--color-bg);
}

.order-book-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.order-book-title {
  font-size: var(--font-size-md);
  font-weight: 500;
  color: var(--color-text);
  max-width: 400rpx;
}

.order-meta {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.status-badge {
  font-size: var(--font-size-sm);
  font-weight: 500;
  padding: 6rpx 18rpx;
  border-radius: var(--border-radius-full);
  background: var(--color-bg);
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.action-btn {
  padding: 12rpx 30rpx;
  font-size: var(--font-size-sm);
  border-radius: var(--border-radius-full);
  background: var(--color-bg);
  color: var(--color-text-secondary);
  border: none;
  line-height: 1.5;
  transition: all 0.2s;
}
.action-btn:active {
  transform: scale(0.95);
  opacity: 0.85;
}
.action-btn::after { border: none; }

.btn-primary-sm {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  color: var(--color-white);
}

.btn-danger-sm {
  background: var(--color-white);
  color: var(--color-danger);
  border: 1rpx solid var(--color-danger);
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  gap: 16rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
}
