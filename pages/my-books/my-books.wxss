/* pages/my-books/my-books.wxss */
.my-book-card {
  background: var(--color-white);
  border-radius: var(--border-radius-md);
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s;
}
.my-book-card:active {
  transform: scale(0.98);
}

.book-main {
  display: flex;
  padding: 20rpx;
}

.book-cover {
  width: 160rpx;
  height: 200rpx;
  border-radius: 10rpx;
  margin-right: 20rpx;
  background: var(--color-bg);
}

.book-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.book-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text);
}

.book-tags {
  display: flex;
  gap: 10rpx;
}

.status-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: var(--border-radius-full);
  font-size: var(--font-size-xs);
}

.book-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.action-btn {
  padding: 12rpx 30rpx;
  font-size: var(--font-size-sm);
  border-radius: var(--border-radius-full);
  background: var(--color-bg);
  color: var(--color-text-secondary);
  border: none;
  line-height: 1.5;
  transition: all 0.2s;
}
.action-btn:active {
  transform: scale(0.95);
  opacity: 0.85;
}
.action-btn::after { border: none; }

.btn-danger-outline {
  background: var(--color-white);
  color: var(--color-danger);
  border: 1rpx solid var(--color-danger);
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
  gap: 16rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
