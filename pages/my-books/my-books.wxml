<!-- pages/my-books/my-books.wxml -->
<view class="page-container">
  <view wx:if="{{loading}}" class="loading-state">
    <view class="spinner"></view>
    <text class="text-secondary text-sm">加载中...</text>
  </view>

  <view wx:elif="{{books.length > 0}}" class="book-list">
    <view
      wx:for="{{books}}"
      wx:key="_id"
      class="my-book-card"
    >
      <view class="book-main" bindtap="goDetail" data-id="{{item._id}}">
        <image class="book-cover" src="{{item.images[0] || item.coverImage || '/assets/images/book-placeholder.png'}}" mode="aspectFill" />
        <view class="book-info">
          <text class="book-title text-ellipsis">{{item.title}}</text>
          <text class="text-sm text-secondary">{{item.author}}</text>
          <view class="book-tags mt-xs">
            <text class="tag">{{conditionMap[item.condition] || item.condition}}</text>
            <text class="status-tag" style="color:{{item.statusInfo.color}}; background:{{item.statusInfo.color}}15">
              {{item.statusInfo.text}}
            </text>
          </view>
          <view class="flex-between mt-xs">
            <text class="price">¥{{item.price}}</text>
            <text class="text-xs text-secondary">{{item.createTimeStr}} · {{item.viewCount || 0}}次浏览</text>
          </view>
        </view>
      </view>

      <view class="book-actions" wx:if="{{item.status === 'on_sale'}}">
        <button class="action-btn" bindtap="goEdit" data-id="{{item._id}}">编辑</button>
        <button class="action-btn btn-danger-outline" bindtap="withdrawBook" data-id="{{item._id}}">下架</button>
      </view>
    </view>
  </view>

  <view wx:else class="empty-state">
    <text class="empty-icon">📖</text>
    <text class="text-secondary">还没有发布过书籍</text>
    <button class="btn-primary mt-lg" bindtap="goPublish">去发布</button>
  </view>
</view>
