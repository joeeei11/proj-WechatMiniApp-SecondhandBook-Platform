/* pages/search/search.wxss */
.search-page {
  min-height: 100vh;
  background: var(--color-bg);
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: var(--color-white);
  gap: 16rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: var(--color-bg-input);
  border-radius: var(--border-radius-full);
  padding: 0 24rpx;
  height: 72rpx;
  border: 2rpx solid transparent;
  transition: all 0.25s;
}

.search-input-wrap.focus {
  border-color: var(--color-primary);
  background: var(--color-white);
  box-shadow: 0 0 0 4rpx var(--color-primary-light);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: var(--font-size-md);
  height: 72rpx;
}

.filter-btn {
  font-size: 26rpx;
  color: var(--color-primary);
  padding: 10rpx 16rpx;
  transition: opacity 0.2s;
}
.filter-btn:active {
  opacity: 0.7;
}

/* 筛选面板 */
.filter-panel {
  background: var(--color-white);
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
  border-top: 1rpx solid var(--color-border-light);
}

.filter-panel.show {
  max-height: 1200rpx;
  padding: 20rpx 24rpx;
}

.filter-group {
  margin-bottom: 24rpx;
}

.filter-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
  display: block;
}

.filter-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-tag {
  padding: 10rpx 24rpx;
  font-size: var(--font-size-sm);
  border-radius: var(--border-radius-full);
  background: var(--color-bg-input);
  color: var(--color-text-secondary);
  transition: all 0.25s;
  border: 2rpx solid transparent;
}

.filter-tag.active {
  background: var(--color-primary-light);
  color: var(--color-primary);
  font-weight: 500;
  border-color: var(--color-primary);
}

.filter-actions {
  display: flex;
  gap: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.filter-actions .btn-outline,
.filter-actions .btn-primary {
  flex: 1;
  text-align: center;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  font-size: var(--font-size-md);
}

/* 结果区域 */
.results-section {
  padding: 20rpx;
}

.results-count {
  font-size: var(--font-size-sm);
  color: var(--color-text-placeholder);
  margin-bottom: 16rpx;
  display: block;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  color: var(--color-text-placeholder);
  gap: 16rpx;
}

/* 结果列表 */
.result-item {
  display: flex;
  background: var(--color-white);
  border-radius: var(--border-radius-md);
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s;
}
.result-item:active {
  transform: scale(0.98);
}

.result-img {
  width: 160rpx;
  height: 200rpx;
  border-radius: 10rpx;
  margin-right: 20rpx;
  background: var(--color-bg);
}

.result-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.result-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text);
}

.result-author {
  margin-top: 8rpx;
}

.result-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
}

.result-college {
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
