/* pages/chat/chat.wxss - 微信风格聊天样式（优化版） */

.chat-page {
  background: #EDEDED;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ========== 自定义导航栏 ========== */
.custom-nav {
  background: #EDEDED;
  position: relative;
  z-index: 100;
}

.nav-status-bar {
  width: 100%;
}

.nav-bar {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 16rpx;
  border-bottom: 1rpx solid #d9d9d9;
}

.nav-back {
  width: 80rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 56rpx;
  color: #333;
  font-weight: 300;
  line-height: 1;
  margin-top: -4rpx;
}

.nav-center {
  flex: 1;
  text-align: center;
  overflow: hidden;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-right {
  width: 80rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-more-icon {
  font-size: 40rpx;
  color: #333;
  font-weight: bold;
  letter-spacing: 2rpx;
}

/* ========== 书籍上下文卡片 ========== */
.book-context {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 18rpx 24rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid #e5e5e5;
}
.book-context:active {
  background: #f5f5f5;
}

.book-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.book-context-info {
  flex: 1;
  overflow: hidden;
}

.book-context-title {
  font-size: 28rpx;
  color: #333;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.book-context-price {
  font-size: 26rpx;
  color: #fa5151;
  font-weight: 600;
}

.book-context-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.book-status-text {
  font-size: 22rpx;
  color: #07c160;
  background: #e8f8ee;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.book-status-text.sold {
  color: #999;
  background: #f0f0f0;
}

.book-arrow {
  font-size: 36rpx;
  color: #c0c0c0;
}

/* ========== 消息列表 ========== */
.msg-list {
  flex: 1;
  height: 0;
}

.msg-list-inner {
  padding: 16rpx 24rpx;
}

.empty-chat {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 180rpx 0 100rpx;
}

.empty-chat-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-chat-text {
  font-size: 28rpx;
  color: #999;
}

/* ========== 时间分隔符 ========== */
.time-divider {
  text-align: center;
  padding: 20rpx 0 24rpx;
}

.time-divider-text {
  font-size: 22rpx;
  color: #999;
  background: rgba(0, 0, 0, 0.05);
  padding: 6rpx 20rpx;
  border-radius: 8rpx;
  letter-spacing: 1rpx;
}

/* ========== 消息项 ========== */
.msg-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 32rpx;
  gap: 16rpx;
  animation: msgSlideIn 0.25s ease-out;
}

.msg-left {
  flex-direction: row;
  padding-right: 80rpx;
}

.msg-right {
  flex-direction: row-reverse;
  padding-left: 80rpx;
}

/* 头像 - 微信方形圆角风格 */
.msg-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #d8d8d8;
}

.msg-content-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
  max-width: 100%;
}

.msg-right .msg-content-wrap {
  flex-direction: row-reverse;
}

/* ========== 消息气泡 ========== */
.msg-bubble {
  padding: 22rpx 28rpx;
  border-radius: 8rpx;
  word-break: break-all;
  position: relative;
}

/* 对方消息 - 白色气泡 */
.msg-bubble-left {
  background: #fff;
  border-top-left-radius: 2rpx;
}

/* 三角箭头 - 左 */
.msg-bubble-left::before {
  content: '';
  position: absolute;
  left: -16rpx;
  top: 24rpx;
  width: 0;
  height: 0;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  border-right: 16rpx solid #fff;
}

/* 自己的消息 - 微信绿气泡 */
.msg-bubble-right {
  background: #95EC69;
  border-top-right-radius: 2rpx;
}

/* 三角箭头 - 右 */
.msg-bubble-right::before {
  content: '';
  position: absolute;
  right: -16rpx;
  top: 24rpx;
  width: 0;
  height: 0;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  border-left: 16rpx solid #95EC69;
}

.msg-text {
  font-size: 32rpx;
  line-height: 1.55;
  color: #1a1a1a;
  letter-spacing: 0.5rpx;
}

/* ========== 图片消息 ========== */
.msg-img-wrap {
  border-radius: 10rpx;
  overflow: hidden;
  max-width: 400rpx;
}

.msg-image {
  width: 100%;
  min-width: 180rpx;
  max-height: 480rpx;
  border-radius: 10rpx;
  display: block;
}

/* 发送中状态 */
.msg-sending {
  display: flex;
  align-items: center;
}

/* ========== 底部输入栏 ========== */
.input-bar {
  background: #F7F7F7;
  border-top: 1rpx solid #dcdcdc;
}

.input-bar-inner {
  display: flex;
  align-items: flex-end;
  gap: 4rpx;
  padding: 14rpx 12rpx;
}

/* 工具栏图标按钮 */
.toolbar-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 8rpx;
}
.toolbar-btn:active {
  background: rgba(0, 0, 0, 0.05);
}

.toolbar-emoji {
  font-size: 48rpx;
  line-height: 1;
}

.toolbar-plus {
  font-size: 56rpx;
  color: #444;
}

/* 输入框 */
.input-wrap {
  flex: 1;
  background: #fff;
  border-radius: 8rpx;
  border: 1rpx solid #dcdcdc;
  min-height: 72rpx;
  display: flex;
  align-items: center;
}

.msg-input {
  flex: 1;
  font-size: 32rpx;
  padding: 16rpx 24rpx;
  max-height: 200rpx;
  min-height: 40rpx;
  line-height: 1.4;
  width: 100%;
  color: #1a1a1a;
}

/* 发送按钮 */
.send-btn {
  background: #07C160;
  border-radius: 10rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
  flex-shrink: 0;
  transition: all 0.15s;
}
.send-btn:active {
  background: #06ad56;
  transform: scale(0.96);
}

.send-btn-text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

/* ========== 更多操作面板 ========== */
.more-panel {
  background: #F7F7F7;
  overflow: hidden;
  max-height: 0;
  transition: max-height 0.25s ease, padding 0.25s ease;
  border-top: 1rpx solid #dcdcdc;
  padding: 0 40rpx;
}

.more-panel.show {
  max-height: 380rpx;
  padding: 28rpx 40rpx 36rpx;
}

.more-grid {
  display: flex;
  gap: 32rpx;
  flex-wrap: wrap;
}

.more-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  width: 120rpx;
}
.more-item:active {
  opacity: 0.7;
  transform: scale(0.95);
}

.more-item-icon {
  width: 112rpx;
  height: 112rpx;
  background: #fff;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.15s;
}

.more-item-text {
  font-size: 22rpx;
  color: #666;
}

/* ========== 动画 ========== */
@keyframes msgSlideIn {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}
