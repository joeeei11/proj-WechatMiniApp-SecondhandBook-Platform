/* pages/chat/chat.wxss */

.chat-page {
  background: var(--color-bg-chat);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 书籍上下文 */
.book-context {
  display: flex;
  align-items: center;
  background: var(--color-white);
  padding: 20rpx 24rpx;
  gap: 20rpx;
  border-bottom: 1rpx solid var(--color-border);
  transition: background 0.15s;
}
.book-context:active {
  background: var(--color-bg);
}

.book-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--border-radius-sm);
  flex-shrink: 0;
  background: var(--color-border);
}

.book-context-info {
  flex: 1;
}

.book-context-title {
  font-size: var(--font-size-sm);
  color: var(--color-text);
  display: block;
  font-weight: 500;
}

/* 消息列表 */
.msg-list {
  flex: 1;
  height: 0; /* 配合 flex:1 使 scroll-view 可滚动 */
  padding: 20rpx;
}

.empty-chat {
  text-align: center;
  padding: 80rpx 0;
}

/* 消息项 */
.msg-item {
  display: flex;
  align-items: flex-end;
  margin-bottom: 24rpx;
  gap: 12rpx;
  animation: fadeIn 0.25s ease-out;
}

.msg-left {
  flex-direction: row;
}

.msg-right {
  flex-direction: row-reverse;
}

.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: var(--color-border);
}

.msg-bubble {
  max-width: 65%;
  padding: 18rpx 24rpx;
  border-radius: 20rpx;
  word-break: break-all;
}

.msg-bubble-left {
  background: var(--color-white);
  border-top-left-radius: 4rpx;
}

.msg-bubble-right {
  background: var(--color-primary);
  border-top-right-radius: 4rpx;
}

.msg-text {
  font-size: var(--font-size-md);
  line-height: 1.6;
}

.msg-bubble-left .msg-text {
  color: var(--color-text);
}

.msg-bubble-right .msg-text {
  color: var(--color-white);
}

/* 输入栏 */
.input-bar {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  background: var(--color-white);
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--color-border);
}

.msg-input {
  flex: 1;
  background: var(--color-bg);
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  font-size: var(--font-size-md);
  max-height: 160rpx;
  min-height: 72rpx;
  line-height: 1.5;
  transition: border-color 0.2s;
  border: 2rpx solid transparent;
}

.msg-input:focus {
  border-color: var(--color-primary);
  background: var(--color-white);
}

.send-btn {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: var(--color-white);
  border-radius: 20rpx;
  font-size: var(--font-size-sm);
  padding: 0 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  border: none;
  flex-shrink: 0;
  white-space: nowrap;
  transition: all 0.2s;
}
.send-btn:active {
  transform: scale(0.95);
}
.send-btn::after { border: none; }

.send-btn[disabled] {
  background: var(--color-border);
  color: var(--color-text-placeholder);
}
