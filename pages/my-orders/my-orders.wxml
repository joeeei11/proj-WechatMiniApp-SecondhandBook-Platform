<!-- pages/my-orders/my-orders.wxml -->
<view class="page-container">
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'buy' ? 'active' : ''}}" bindtap="switchTab" data-tab="buy">我购买的</view>
    <view class="tab-item {{activeTab === 'sell' ? 'active' : ''}}" bindtap="switchTab" data-tab="sell">我出售的</view>
  </view>

  <view wx:if="{{loading}}" class="loading-state">
    <view class="spinner"></view>
    <text class="text-secondary text-sm">加载中...</text>
  </view>

  <view wx:elif="{{orders.length > 0}}">
    <view wx:for="{{orders}}" wx:key="_id" class="order-card">
      <view class="order-book flex" bindtap="goBookDetail" data-id="{{item.bookId}}">
        <image class="order-book-img" src="{{item.bookCoverImage || '/assets/images/book-placeholder.png'}}" mode="aspectFill" />
        <view class="order-book-info">
          <text class="order-book-title text-ellipsis">{{item.bookTitle}}</text>
          <text class="text-danger">¥{{item.price}}</text>
        </view>
      </view>
      <view class="order-meta flex-between">
        <text class="text-xs text-secondary">{{item.createTimeStr}}</text>
        <view class="status-badge" style="color:{{item.statusInfo.color}}">{{item.statusInfo.text}}</view>
      </view>
      <view class="order-actions" wx:if="{{item.status !== 'cancelled'}}">
        <block wx:if="{{activeTab === 'buy'}}">
          <button class="action-btn" bindtap="contactSeller" data-seller-id="{{item.sellerId}}" data-book-id="{{item.bookId}}">联系卖家</button>
          <button class="action-btn btn-danger-sm" bindtap="cancelOrder" data-order-id="{{item._id}}" wx:if="{{item.status === 'pending'}}">取消</button>
          <button class="action-btn btn-primary-sm" bindtap="goReview" data-order-id="{{item._id}}" data-reviewee-id="{{item.sellerId}}" wx:if="{{item.status === 'completed' && !item.reviewed}}">评价</button>
        </block>
        <block wx:if="{{activeTab === 'sell'}}">
          <button class="action-btn" bindtap="contactBuyer" data-buyer-id="{{item.buyerId}}" data-book-id="{{item.bookId}}">联系买家</button>
          <button class="action-btn btn-primary-sm" bindtap="confirmOrder" data-order-id="{{item._id}}" data-book-id="{{item.bookId}}" wx:if="{{item.status === 'pending' || item.status === 'confirmed'}}">确认完成</button>
        </block>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:elif="{{!loading}}">
    <text class="empty-icon">📦</text>
    <text class="text-secondary">暂无订单</text>
  </view>
</view>
