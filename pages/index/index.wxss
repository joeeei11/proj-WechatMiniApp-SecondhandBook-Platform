/* pages/index/index.wxss - 首页样式 */

/* 搜索栏 */
.header-search {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  padding: 20rpx 24rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-bar {
  background: rgba(255,255,255,0.2);
  border-radius: var(--border-radius-full);
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  transition: background 0.2s;
}
.search-bar:active {
  background: rgba(255,255,255,0.3);
}

.search-icon {
  font-size: 28rpx;
}

.search-placeholder {
  color: rgba(255,255,255,0.8);
  font-size: var(--font-size-sm);
  flex: 1;
}

/* 学院筛选 */
.college-filter {
  background: var(--color-white);
  white-space: nowrap;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.college-tag {
  display: inline-block;
  padding: 10rpx 28rpx;
  border-radius: var(--border-radius-full);
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  background: var(--color-bg);
  margin-right: 12rpx;
  border: 2rpx solid transparent;
  white-space: nowrap;
  transition: all 0.25s ease;
}

.college-tag.active {
  color: var(--color-primary);
  background: var(--color-primary-light);
  border-color: var(--color-primary);
  font-weight: 500;
}

/* 书籍网格 */
.books-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  background: var(--color-bg);
}

.book-card {
  background: var(--color-white);
  border-radius: var(--border-radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.book-card:active {
  transform: scale(0.97);
  box-shadow: var(--shadow-md);
}

/* 封面 */
.book-cover-wrap {
  position: relative;
  width: 100%;
  padding-top: 133%;
  overflow: hidden;
}

.book-cover {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: var(--color-bg);
}

.book-status-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--border-radius-full);
  font-size: var(--font-size-xs);
  color: white;
  background: rgba(0,0,0,0.5);
  backdrop-filter: blur(4px);
}

.book-status-badge.sold {
  background: rgba(153,153,153,0.85);
}
.book-status-badge.trading {
  background: rgba(74,144,226,0.85);
}

/* 书籍信息 */
.book-info {
  padding: 16rpx;
}

.book-title {
  font-size: var(--font-size-sm);
  color: var(--color-text);
  font-weight: 500;
  line-height: 1.4;
  margin-bottom: 10rpx;
  display: block;
}

.book-meta {
  margin-bottom: 12rpx;
}

.book-condition {
  font-size: 20rpx;
}

.book-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.book-college {
  max-width: 130rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 骨架屏 */
.skeleton-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  background: var(--color-bg);
}

.skeleton-card {
  background: var(--color-white);
  border-radius: var(--border-radius-md);
  overflow: hidden;
}

.skeleton-cover {
  width: 100%;
  padding-top: 133%;
}

.skeleton-info {
  padding: 16rpx;
}

.skeleton-title {
  height: 28rpx;
  margin-bottom: 12rpx;
  width: 80%;
}

.skeleton-tag {
  height: 24rpx;
  width: 40%;
  margin-bottom: 12rpx;
}

.skeleton-price {
  height: 28rpx;
  width: 30%;
}

/* 加载更多 */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 30rpx;
  color: var(--color-text-placeholder);
  font-size: var(--font-size-sm);
}

.no-more {
  text-align: center;
  padding: 30rpx;
  color: var(--color-text-placeholder);
  font-size: var(--font-size-sm);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.4;
}

.empty-text {
  color: var(--color-text-placeholder);
  font-size: var(--font-size-md);
  margin-bottom: 30rpx;
}

.empty-action {
  margin-top: 10rpx;
  padding: 16rpx 48rpx;
  background: var(--color-primary);
  color: var(--color-white);
  border-radius: var(--border-radius-full);
  font-size: var(--font-size-sm);
  border: none;
}
.empty-action::after { border: none; }
