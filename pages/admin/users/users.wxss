/* pages/admin/users/users.wxss */
.user-card {
  background: #fff; border-radius: 16rpx; padding: 20rpx;
  margin-bottom: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.user-row { display: flex; align-items: center; }
.user-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; margin-right: 16rpx; background: #eee; }
.user-info { flex: 1; }
.user-name { font-size: 28rpx; font-weight: 500; display: block; }
.admin-actions { display: flex; justify-content: flex-end; gap: 12rpx; margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #f5f5f5; }
.action-btn { padding: 8rpx 24rpx; font-size: 24rpx; border-radius: 20rpx; background: #f5f5f5; color: #666; border: none; line-height: 1.5; }
.action-btn::after { border: none; }
.btn-primary-sm { background: #4A90E2; color: #fff; }
.btn-danger-sm { background: #fff; color: #F56C6C; border: 1rpx solid #F56C6C; }
.loading-state { text-align: center; padding: 80rpx 0; }
.empty-state { text-align: center; padding: 80rpx 0; }
