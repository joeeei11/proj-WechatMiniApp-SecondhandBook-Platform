<!-- pages/admin/stats/stats.wxml -->
<view class="page-container">
  <view wx:if="{{loading}}" class="loading-state"><text class="text-secondary">加载中...</text></view>

  <block wx:else>
    <!-- 统计卡片 -->
    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-value">{{stats.totalUsers}}</text>
        <text class="stat-label">注册用户</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">{{stats.totalBooks}}</text>
        <text class="stat-label">总书籍</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">{{stats.totalOrders}}</text>
        <text class="stat-label">总订单</text>
      </view>
      <view class="stat-card highlight">
        <text class="stat-value">{{stats.completionRate}}%</text>
        <text class="stat-label">完成率</text>
      </view>
    </view>

    <!-- 热门书籍 -->
    <view class="section card">
      <text class="section-title">🔥 热门书籍 TOP10</text>
      <view wx:for="{{topBooks}}" wx:key="_id" class="rank-item">
        <text class="rank-num">{{index + 1}}</text>
        <text class="rank-title text-ellipsis">{{item.title}}</text>
        <text class="rank-count text-xs text-secondary">{{item.viewCount || 0}}次浏览</text>
      </view>
      <view wx:if="{{topBooks.length === 0}}" class="text-secondary text-center">暂无数据</view>
    </view>

    <!-- 最近订单 -->
    <view class="section card">
      <text class="section-title">📋 最近订单</text>
      <view wx:for="{{recentOrders}}" wx:key="_id" class="order-row">
        <text class="order-id text-xs text-secondary">{{item._id}}</text>
        <text class="order-status" style="color:{{item.status === 'completed' ? '#67C23A' : item.status === 'cancelled' ? '#999' : '#E6A23C'}}">
          {{item.status === 'completed' ? '已完成' : item.status === 'cancelled' ? '已取消' : item.status === 'confirmed' ? '交易中' : '待确认'}}
        </text>
        <text class="order-price text-danger">¥{{item.price}}</text>
      </view>
      <view wx:if="{{recentOrders.length === 0}}" class="text-secondary text-center">暂无数据</view>
    </view>
  </block>
</view>
